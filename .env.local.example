NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Beta access code for signup (server-side only)
BETA_CODE=your-beta-code-here

# Fail-closed by default. Set to "true" ONLY to allow the BETA_CODE env fallback
# when the database validation function is unavailable (e.g. during migration).
# Leave unset/false in production.
ACTIVATION_CODE_ALLOW_ENV_FALLBACK=false

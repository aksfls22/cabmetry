      {/* Period Navigation */}
      <div className="flex items-center justify-between rounded-xl border border-surface-border bg-surface-raised px-4 py-3">
        {/* Quick Navigation */}
<div className="flex flex-wrap gap-2">
  {periodType === "dia" && (

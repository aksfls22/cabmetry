      </label>
      <select
        id={selectId}
        className={cn(
          "touch-target w-full appearance-none rounded-2xl border border-surface-border bg-surface-raised px-4 py-4 text-lg text-white focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30",
